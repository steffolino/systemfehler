# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
dist/
build/
# Virtual environments (any name starting with .venv or venv)
.venv*/
venv*/
ENV/

# ── Node / Frontend ───────────────────────────────────────────────────────
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.vite/

# ── Secrets / config ──────────────────────────────────────────────────────
.env
.env.*
# keep .env.example if it exists
!.env.example
docs/.env

# ── RAG pipeline — generated / large binary assets ────────────────────────
# Extracted text cache (regenerated by `python -m crawlers.rag index`)
data/_rag_cache/
# Local PDF corpus (203 MB+, too large for git — see docs/rag-overview.md)
data/_rag_sources/local/
# Loose PDFs dumped in data/ root before being moved to local/
data/*.pdf
data/Buerger*.pdf
data/policy_*.pdf
data/fw-*.pdf
data/dok_*.pdf
data/merkblatt-*.pdf

# ── Crawler / pipeline outputs ────────────────────────────────────────────
data/**/candidates.json
data/**/crawl_metrics.json
data/**/url_status.jsonl
data/_topics/discovery/*.json
data/snapshots/
data/_quality/llm_costs.jsonl

# ── Moderation queue (contains PII / pre-publication content) ─────────────
moderation/review_queue.json

# ── Databases ─────────────────────────────────────────────────────────────
*.sqlite
*.db
postgres_data/

# ── Build / deploy output ─────────────────────────────────────────────────
dist-pages/
cloudflare-pages/functions/dist/
.deploy-main/
# Wrangler local dev state (cache, KV, D1 snapshots — not for git)
.wrangler/

# ── Logs ──────────────────────────────────────────────────────────────────
logs/
*.log

# ── Test / lint caches ────────────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml

# ── Editor / OS ───────────────────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db
ehthumbs.db
.cache/
.tmp/

# ── Misc temp files ───────────────────────────────────────────────────────
oft

{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://systemfehler.dev/schemas/moderation-queue.schema.json",
    "title": "Systemfehler Moderation Queue Entry",
    "type": "object",
    "required": [
        "id",
        "domain",
        "action",
        "status",
        "candidateData",
        "diff",
        "provenance",
        "createdAt"
    ],
    "properties": {
        "id": {
            "type": "string"
        },
        "entryId": {
            "type": [
                "string",
                "null"
            ]
        },
        "domain": {
            "type": "string",
            "enum": [
                "benefits",
                "aid",
                "tools",
                "organizations",
                "contacts"
            ]
        },
        "action": {
            "type": "string",
            "enum": [
                "create",
                "update",
                "delete"
            ]
        },
        "status": {
            "type": "string",
            "enum": [
                "pending",
                "approved",
                "rejected",
                "accepted"
            ]
        },
        "candidateData": {
            "type": [
                "object",
                "null"
            ]
        },
        "existingData": {
            "type": [
                "object",
                "null"
            ]
        },
        "diff": {
            "type": "object"
        },
        "diffSummary": {
            "type": [
                "object",
                "null"
            ]
        },
        "importantChanges": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "provenance": {
            "type": "object",
            "required": [
                "source",
                "crawledAt",
                "crawlerVersion"
            ],
            "properties": {
                "source": {
                    "type": "string"
                },
                "crawledAt": {
                    "type": "string"
                },
                "crawlerVersion": {
                    "type": "string"
                }
            },
            "additionalProperties": true
        },
        "reviewedBy": {
            "type": [
                "string",
                "null"
            ]
        },
        "reviewedAt": {
            "type": [
                "string",
                "null"
            ]
        },
        "createdAt": {
            "type": "string"
        },
        "updatedAt": {
            "type": [
                "string",
                "null"
            ]
        }
    },
    "additionalProperties": true
}
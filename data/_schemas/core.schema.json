{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://systemfehler.github.io/schemas/core.schema.json",
  "title": "Systemfehler Core Schema",
  "description": "Core schema for unified social-services entries. All domain entries inherit from this schema.",
  "version": "0.1.0",
  "type": "object",
  "properties": {
    "id": {
      "anyOf": [
        {
          "type": "string",
          "format": "uuid"
        },
        {
          "type": "object",
          "title": "UUID object"
        }
      ],
      "description": "Persistent unique identifier (string or UUID object)"
    },
    "title": {
      "type": "string",
      "description": "Display title as plain text"
    },
    "summary": {
      "$ref": "#/definitions/multilingualText",
      "description": "Short description in multiple languages"
    },
    "content": {
      "$ref": "#/definitions/multilingualText",
      "description": "Main extracted text content"
    },
    "url": {
      "type": "string",
      "format": "uri",
      "description": "Primary source URL"
    },
    "topics": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Normalized taxonomy topic terms"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Additional classification tags"
    },
    "targetGroups": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Target audience groups"
    },
    "validFrom": {
      "type": [
        "string",
        "null"
      ],
      "format": "date",
      "description": "Start date of validity (ISO 8601)"
    },
    "validUntil": {
      "type": [
        "string",
        "null"
      ],
      "format": "date",
      "description": "End date of validity (ISO 8601)"
    },
    "deadline": {
      "type": [
        "string",
        "null"
      ],
      "format": "date",
      "description": "Application or action deadline (ISO 8601)"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "discontinued",
        "archived",
        "under_revision"
      ],
      "description": "Current lifecycle status"
    },
    "firstSeen": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when entry was first crawled"
    },
    "lastSeen": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when entry was last seen in source"
    },
    "sourceUnavailable": {
      "type": "boolean",
      "description": "True if source is no longer accessible"
    },
    "provenance": {
      "$ref": "#/definitions/provenance",
      "description": "Data origin and tracking metadata"
    },
    "qualityScores": {
      "$ref": "#/definitions/qualityScores",
      "description": "Computed quality and AI searchability scores"
    },
    "translations": {
      "anyOf": [
        {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "minLength": 2
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "title": {
                "type": "string"
              },
              "summary": {
                "type": "string"
              },
              "body": {
                "type": "string"
              },
              "provenance": {
                "$ref": "#/definitions/provenanceDetailed"
              },
              "method": {
                "type": "string",
                "enum": [
                  "llm",
                  "rule",
                  "human",
                  "mt"
                ]
              },
              "generator": {
                "type": "string"
              },
              "timestamp": {
                "type": "string",
                "format": "date-time"
              },
              "reviewed": {
                "type": "boolean"
              },
              "variant": {
                "type": "string",
                "enum": [
                  "einfach",
                  "leicht"
                ]
              },
              "reviewStatus": {
                "type": "string",
                "enum": [
                  "suggested",
                  "approved",
                  "rejected"
                ]
              },
              "reviewedBy": {
                "type": "string"
              },
              "reviewedAt": {
                "type": "string",
                "format": "date-time"
              }
            },
            "additionalProperties": false,
            "required": [
              "title",
              "timestamp",
              "provenance"
            ]
          }
        },
        {
          "type": "null"
        }
      ],
      "description": "Map of language codes to translation objects (or null)"
    }
  },
  "required": [
    "id",
    "title",
    "url",
    "status",
    "provenance"
  ],
  "definitions": {
    "multilingualText": {
      "type": "object",
      "properties": {
        "de": {
          "type": [
            "string",
            "null"
          ]
        },
        "en": {
          "type": [
            "string",
            "null"
          ]
        },
        "easy_de": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": {
        "type": [
          "string",
          "null"
        ]
      }
    },
    "translations": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 2
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "body": {
            "type": "string"
          },
          "provenance": {
            "$ref": "#/definitions/provenanceDetailed"
          },
          "method": {
            "type": "string",
            "enum": [
              "llm",
              "rule",
              "human",
              "mt"
            ]
          },
          "generator": {
            "type": "string"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "reviewed": {
            "type": "boolean"
          },
          "variant": {
            "type": "string",
            "enum": [
              "einfach",
              "leicht"
            ]
          },
          "reviewStatus": {
            "type": "string",
            "enum": [
              "suggested",
              "approved",
              "rejected"
            ]
          },
          "reviewedBy": {
            "type": "string"
          },
          "reviewedAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false,
        "required": [
          "title",
          "timestamp",
          "provenance"
        ]
      },
      "description": "Map of language codes to translation objects (keys SHOULD be IETF language tags or project-specific codes)"
    },
    "provenance": {
      "type": "object",
      "properties": {
        "source": {
          "type": "string",
          "description": "Source domain or organization"
        },
        "crawlId": {
          "type": "string",
          "description": "Identifier of the crawl run"
        },
        "crawlerVersion": {
          "type": "string",
          "description": "Version of crawler implementation"
        },
        "checksum": {
          "type": "string",
          "description": "Content checksum for change detection"
        },
        "crawledAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "source",
        "crawledAt"
      ],
      "additionalProperties": true
    },
    "provenanceDetailed": {
      "type": "object",
      "properties": {
        "source": {
          "type": "string",
          "description": "Source domain or organization"
        },
        "crawlId": {
          "type": "string",
          "description": "Identifier of the crawl run"
        },
        "crawlerVersion": {
          "type": "string",
          "description": "Version of crawler implementation"
        },
        "checksum": {
          "type": "string",
          "description": "Content checksum for change detection"
        },
        "crawledAt": {
          "type": "string",
          "format": "date-time"
        },
        "method": {
          "type": "string",
          "description": "How translation was generated (llm|rule|human|mt)"
        },
        "generator": {
          "type": "string",
          "description": "Model or tool used for generation"
        }
      },
      "required": [
        "source",
        "crawledAt"
      ],
      "additionalProperties": true
    },
    "qualityScores": {
      "type": "object",
      "properties": {
        "iqs": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Information Quality Score"
        },
        "ais": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "AI Searchability Score"
        },
        "computedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}

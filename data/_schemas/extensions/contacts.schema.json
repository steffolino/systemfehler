{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://systemfehler.github.io/schemas/extensions/contacts.schema.json",
  "title": "Systemfehler Contacts Extension Schema",
  "description": "Extension schema for contact and advisor attributes. Extends core schema.",
  "version": "0.1.0",
  "type": "object",
  "allOf": [
    {
      "$ref": "../core.schema.json"
    }
  ],
  "properties": {
    "contactType": {
      "type": "string",
      "description": "Type of contact (helpline, advisor, office, etc.)"
    },
    "specialization": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Areas of specialization"
    },
    "eligibilityCriteria": {
      "$ref": "#/definitions/multilingualText",
      "description": "Eligibility or intake requirements for using the contact point"
    },
    "availability": {
      "type": "object",
      "properties": {
        "hours": {
          "type": "string"
        },
        "languages": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "linkedOrganization": {
      "type": "string",
      "description": "Reference to parent organization"
    }
  },
  "definitions": {
    "multilingualText": {
      "type": "object",
      "properties": {
        "de": {
          "type": [
            "string",
            "null"
          ]
        },
        "en": {
          "type": [
            "string",
            "null"
          ]
        },
        "easy_de": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": {
        "type": [
          "string",
          "null"
        ]
      }
    }
  }
}

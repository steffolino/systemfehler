{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://systemfehler.github.io/schemas/extensions/benefits.schema.json",
  "title": "Systemfehler Benefits Extension Schema",
  "description": "Extension schema for benefit-specific attributes. Extends core schema.",
  "version": "0.1.0",
  "type": "object",
  "allOf": [
    {
      "$ref": "../core.schema.json"
    }
  ],
  "properties": {
    "benefitAmount": {
      "$ref": "#/definitions/multilingualText",
      "description": "Benefit amount or range description"
    },
    "duration": {
      "type": "string",
      "description": "Duration of benefit eligibility"
    },
    "eligibilityCriteria": {
      "$ref": "#/definitions/multilingualText",
      "description": "Eligibility requirements and conditions"
    },
    "applicationSteps": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/multilingualText"
      },
      "description": "Step-by-step application process"
    },
    "requiredDocuments": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/multilingualText"
      },
      "description": "List of required documents"
    },
    "formLink": {
      "type": "string",
      "format": "uri",
      "description": "Link to application form"
    },
    "contactInfo": {
      "$ref": "#/definitions/contactInfo",
      "description": "Contact information for this benefit"
    }
  },
  "definitions": {
    "multilingualText": {
      "type": "object",
      "properties": {
        "de": {
          "type": [
            "string",
            "null"
          ]
        },
        "en": {
          "type": [
            "string",
            "null"
          ]
        },
        "easy_de": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": {
        "type": [
          "string",
          "null"
        ]
      }
    },
    "contactInfo": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "phone": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "address": {
          "type": "string"
        }
      }
    }
  }
}
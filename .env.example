# Systemfehler .env template
# Copy to .env and adjust as needed

# API
API_PORT=3001

# AI Service
AI_PORT=8002
AI_PROVIDER=ollama
AI_DEFAULT_MODEL=qwen2.5:3b
AI_MODEL_REWRITE=qwen2.5:3b
AI_MODEL_SYNTHESIZE=qwen2.5:3b
AI_MODEL_ENRICH=qwen2.5:3b
# Legacy sidecar path. For recommended local Pages flow (`npm run dev:all`),
# frontend and API are same-origin at http://127.0.0.1:8788 and this can stay unset.
VITE_AI_API_URL=http://localhost:8002
VITE_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
API_REQUIRE_TURNSTILE_FOR_SEARCH=false
AI_RETRIEVAL_MODE=keyword
AI_RETRIEVAL_STRICT_OFFICIAL=false
AI_RETRIEVAL_MIN_SOURCE_TIER=
AI_RETRIEVAL_MIN_CONFIDENCE=0
AI_RETRIEVAL_ENDPOINT=
AI_RETRIEVAL_API_KEY=
AI_RETRIEVAL_ALLOWED_HOSTS=
AI_RETRIEVAL_TIMEOUT_MS=7000
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OPENAI_API_KEY=sk-your-api-key-here

# RAG Pipeline — local PDF corpus
# Point this at wherever you store the local PDF files (they are NOT in git).
# Default (if unset): data/_rag_sources/local/ inside the repo.
# Example for the shared sibling directory:
# RAG_LOCAL_DIR=C:\Users\StretzS\projects\systemfehler-data\local

# Database
POSTGRES_DB=systemfehler
POSTGRES_USER=systemfehler
POSTGRES_PASSWORD=dev_password
POSTGRES_PORT=5432
DATABASE_URL=postgresql://systemfehler:dev_password@127.0.0.1:5432/systemfehler

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
